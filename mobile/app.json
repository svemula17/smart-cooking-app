{
  "expo": {
    "name": "SmartCooking",
    "slug": "SmartCooking",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.svemula17.smartcooking"
    },
    "android": {
      "package": "com.svemula17.smartcooking",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "caf8e2dc-7381-4368-9d9a-896e082cefd9"
      }
    },
    "owner": "svemula17",
    "plugins": [
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "SmartCooking uses your photos to scan grocery receipts and add items to your pantry.",
          "cameraPermission": "SmartCooking uses your camera to scan grocery receipts and add items to your pantry."
        }
      ],
      "expo-audio"
    ]
  }
}
