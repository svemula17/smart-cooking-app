# Copy this file to .env and fill in values for local dev.
# Any variable prefixed with EXPO_PUBLIC_ is inlined into the JS bundle at build time.

# ─── LOCAL DEV ───────────────────────────────────────────────────────────────
# Your Mac's LAN IP for testing on a real device in Expo Go.
# Find it with: ipconfig getifaddr en0
EXPO_PUBLIC_DEV_HOST=10.0.0.34

# ─── PRODUCTION (set in EAS Build secrets, not here) ─────────────────────────
# Option A — One gateway URL for all services (Railway with path-based routing):
# EXPO_PUBLIC_API_BASE_URL=https://api.smartcooking.app

# Option B — Per-service URLs (Railway with one HTTPS domain per service):
# EXPO_PUBLIC_USER_API=https://user.smartcooking.app
# EXPO_PUBLIC_RECIPE_API=https://recipe.smartcooking.app
# EXPO_PUBLIC_NUTRITION_API=https://nutrition.smartcooking.app
# EXPO_PUBLIC_AI_API=https://ai.smartcooking.app
# EXPO_PUBLIC_SHOPPING_API=https://shopping.smartcooking.app
# EXPO_PUBLIC_HOUSE_API=https://house.smartcooking.app
