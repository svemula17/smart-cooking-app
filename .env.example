# ===== Shared =====
NODE_ENV=development
LOG_LEVEL=info

# ===== Postgres =====
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=smartcooking
POSTGRES_USER=cooking
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql://cooking:change_me@postgres:5432/smartcooking

# ===== Redis =====
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# ===== Auth =====
JWT_SECRET=replace_with_long_random_string
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# ===== Service Ports =====
USER_SERVICE_PORT=4001
RECIPE_SERVICE_PORT=4002
NUTRITION_SERVICE_PORT=4003
AI_SERVICE_PORT=4004
SHOPPING_SERVICE_PORT=4005

# ===== Service URLs (internal) =====
USER_SERVICE_URL=http://user-service:4001
RECIPE_SERVICE_URL=http://recipe-service:4002
NUTRITION_SERVICE_URL=http://nutrition-service:4003
AI_SERVICE_URL=http://ai-service:4004
SHOPPING_SERVICE_URL=http://shopping-service:4005

# ===== AI / LLM =====
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AI_MODEL=claude-opus-4-7

# ===== Nutrition data provider =====
USDA_FDC_API_KEY=

# ===== Grocery integrations =====
INSTACART_CLIENT_ID=
INSTACART_CLIENT_SECRET=
WALMART_API_KEY=
WALMART_API_SECRET=

# ===== Mobile =====
API_BASE_URL=http://localhost:4001
